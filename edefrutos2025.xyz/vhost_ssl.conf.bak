# Configuración de proxy para Gunicorn
ProxyPreserveHost On
ProxyRequests Off
ProxyVia On

# Excluir archivos estáticos del proxy
<IfModule mod_proxy.c>
    ProxyPass /static/ !
</IfModule>

# Configuración principal del proxy
ProxyPass / http://127.0.0.1:8000/
ProxyPassReverse / http://127.0.0.1:8000/

# Servir archivos estáticos directamente desde Apache
Alias /static/ /var/www/vhosts/edefrutos2025.xyz/httpdocs/static/

<Directory /var/www/vhosts/edefrutos2025.xyz/httpdocs/static/>
    Options -Indexes +FollowSymLinks
    AllowOverride None
    Require all granted
</Directory>
